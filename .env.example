# ─────────────────────────────────────────
# Xane PMS — Environment Variables Template
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Database ───────────────────────────────
# Supabase PostgreSQL connection string (pooler recommended)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Default Hotel (seed data) ──────────────
HOTEL_NAME="Your Hotel Name"
HOTEL_ADDRESS="Your Hotel Address"
ADMIN_EMAIL="admin@yourhotel.com"
ADMIN_PASSWORD="change_me_in_production"

# ── Server ─────────────────────────────────
PORT=3000

# ── Email (Resend) ─────────────────────────
# Get your API key from: https://resend.com/api-keys
# In sandbox mode, emails only send to your verified Resend email.
# To send to all recipients, verify a domain at: https://resend.com/domains
RESEND_API_KEY="re_your_api_key_here"
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_your_api_key_here"
# Change sender domain once your domain is verified on Resend
SMTP_FROM='"Your Hotel PMS" <noreply@yourdomain.com>'

# ── Super Admin ────────────────────────────
# Master admin for managing all hotel tenants
SUPER_ADMIN_EMAIL="superadmin@yourdomain.com"
SUPER_ADMIN_PASSWORD="change_me_strong_password"
